# Azure AD (Microsoft Entra) app registration settings
AZURE_TENANT_ID=
AZURE_CLIENT_ID=

# SharePoint Online host only (no https://)
SHAREPOINT_HOST={tenantName}.sharepoint.com

# Site path for OData call (example: /sites/yoursite)
SHAREPOINT_SITE_PATH=

# Certificate-based auth settings (preferred for SharePoint app-only)
AZURE_CERT_PFX_PATH=.\cert-output\spo-app-only.pfx
AZURE_CERT_PFX_PASSWORD=


